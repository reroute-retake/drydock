# Copy to .env and fill in. NEVER commit .env (it is gitignored). (P12/C8)

# Hosted provider key (used by the gateway to reach the hosted model).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Gateway master key. Clients (ForgeCode) send this as their OPENAI_API_KEY.
# Any non-empty string works for local use.
LITELLM_MASTER_KEY=sk-drydock-local
